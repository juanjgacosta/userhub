{
  "name": "crud-typeorm-sqlite",
  "version": "1.1.2",
  "main": "app.js",
  "repository": "git@github.com:juanjgacosta/crud-typeorm-sqlite.git",
  "author": "<juan_jg@hotmail.com>",
  "license": "MIT",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsx watch --inspect=0.0.0.0:9220 src/server.ts",
    "typeorm": "tsx watch ./node_modules/typeorm/cli.js",
    "dev:migration:create": "typeorm migration:create ./src/shared/database/migrations/$npm_config_name",
    "dev:migration:run": "npm run typeorm -- migration:run -d ./src/shared/database/DataSource.ts",
    "dev:migration:revert": "npm run typeorm -- migration:revert -d ./src/shared/database/DataSource.ts",
    "test": "jest"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "reflect-metadata": "^0.1.13",
    "sqlite3": "^5.1.6",
    "swagger-ui-express": "^5.0.1",
    "tsyringe": "^4.10.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.3",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.5.1",
    "@types/uuid": "^9.0.2",
    "express-async-errors": "^3.1.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsx": "^3.12.7",
    "typescript": "^5.1.6"
  }
}
